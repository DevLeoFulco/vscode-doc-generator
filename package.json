{
  "name": "vscode-doc-generator",
  "displayName": "Documentação Técnica Generator",
  "description": "Gera documentação técnica automaticamente para seu projeto",
  "version": "0.1.0",
  "publisher": "seu-nome",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:extension.generateDoc"
  ],
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.generateDoc",
        "title": "Gerar Documentação Técnica"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^14.18.63",
    "@types/vscode": "^1.50.0",
    "typescript": "^4.0.5"
  }
}
